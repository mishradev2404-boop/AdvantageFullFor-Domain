{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/services",
      "destination": "/services.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/story",
      "destination": "/story.html"
    },
    {
      "source": "/resources",
      "destination": "/resources.html"
    },
    {
      "source": "/services/linkedin-ads-management",
      "destination": "/services/linkedin-ads-management.html"
    },
    {
      "source": "/services/social-media-management",
      "destination": "/services/social-media-management.html"
    },
    {
      "source": "/services/content-marketing",
      "destination": "/services/content-marketing.html"
    },
    {
      "source": "/services/performance-review",
      "destination": "/services/performance-review.html"
    },
    {
      "source": "/playbooks/linkedin-lead-gen-forms",
      "destination": "/playbooks/linkedin-lead-gen-forms.html"
    },
    {
      "source": "/playbooks/linkedin-campaign-optimisation",
      "destination": "/playbooks/linkedin-campaign-optimisation.html"
    },
    {
      "source": "/playbooks/linkedin-follower-growth",
      "destination": "/playbooks/linkedin-follower-growth.html"
    }
  ],
  "headers": [
    {
      "source": "/(home|_header|_footer).html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
